{
  "launch_config": {
    "version": "4.0",
    "name": "AirOne Professional Ultimate Unified Edition",
    "description": "Complete Integration of ALL Features"
  },
  
  "default_settings": {
    "default_mode": "gui",
    "default_theme": "modern_dark",
    "default_language": "en",
    "auto_update": true,
    "check_updates_on_startup": true,
    "send_analytics": false
  },
  
  "gui_settings": {
    "window": {
      "width": 1600,
      "height": 900,
      "position_x": 100,
      "position_y": 100,
      "fullscreen": false,
      "maximized": true,
      "always_on_top": false
    },
    "appearance": {
      "theme": "modern_dark",
      "font_family": "Segoe UI",
      "font_size": 13,
      "icon_size": 24,
      "animation_enabled": true,
      "transparency": 0.95
    },
    "dashboard": {
      "refresh_rate_ms": 1000,
      "show_grid": true,
      "show_notifications": true,
      "auto_scroll_logs": true,
      "max_log_entries": 1000
    },
    "graphs": {
      "default_type": "altitude_vs_time",
      "auto_scale": true,
      "show_legend": true,
      "anti_aliasing": true,
      "export_format": "png",
      "export_dpi": 300
    }
  },
  
  "cli_settings": {
    "verbose": false,
    "quiet": false,
    "debug": false,
    "color_output": true,
    "log_to_file": true,
    "max_log_size_mb": 50
  },
  
  "web_settings": {
    "host": "127.0.0.1",
    "port": 5000,
    "debug": false,
    "ssl_enabled": false,
    "ssl_cert_path": "",
    "ssl_key_path": "",
    "cors_enabled": true,
    "allowed_origins": ["*"],
    "max_connections": 100,
    "session_timeout_minutes": 60
  },
  
  "simulation_settings": {
    "default_speed": 1.0,
    "max_speed": 10.0,
    "auto_run": false,
    "default_duration_seconds": 300,
    "save_results": true,
    "output_format": "json",
    "real_time_sync": false
  },
  
  "data_settings": {
    "data_directory": "data",
    "backup_directory": "backups",
    "log_directory": "logs",
    "config_directory": "config",
    "auto_backup": true,
    "backup_interval_hours": 24,
    "max_backups": 10,
    "compression_enabled": true
  },
  
  "security_settings": {
    "authentication_required": true,
    "session_timeout_minutes": 60,
    "max_login_attempts": 5,
    "lockout_duration_minutes": 30,
    "password_min_length": 8,
    "require_special_chars": true,
    "password_history_count": 5,
    "two_factor_enabled": false,
    "biometric_enabled": false
  },
  
  "ai_settings": {
    "enabled": true,
    "model": "deepseek_r1_8b",
    "local_mode": true,
    "cache_responses": true,
    "max_context_length": 4096,
    "temperature": 0.7,
    "auto_suggest": true,
    "voice_enabled": false
  },
  
  "hardware_settings": {
    "auto_detect": true,
    "polling_interval_ms": 100,
    "timeout_ms": 5000,
    "retry_count": 3,
    "log_raw_data": false,
    "calibration_enabled": true
  },
  
  "network_settings": {
    "telemetry_enabled": true,
    "telemetry_server": "telemetry.airone.local",
    "telemetry_port": 8080,
    "telemetry_protocol": "udp",
    "reconnect_interval_seconds": 30,
    "buffer_size": 65535
  },
  
  "performance_settings": {
    "enable_profiling": false,
    "enable_metrics": true,
    "metrics_interval_seconds": 60,
    "optimize_memory": true,
    "cache_enabled": true,
    "cache_size_mb": 512,
    "thread_pool_size": 4,
    "async_io": true
  },
  
  "quick_launch_profiles": {
    "development": {
      "mode": "cli",
      "no_auth": true,
      "debug": true,
      "verbose": true,
      "description": "Development mode with debug and no authentication"
    },
    "demo": {
      "mode": "sim",
      "auto_run": true,
      "duration": 60,
      "speed": 1.0,
      "description": "Demo mode with auto-running simulation"
    },
    "production_web": {
      "mode": "web",
      "host": "0.0.0.0",
      "port": 5000,
      "debug": false,
      "description": "Production web server on all interfaces"
    },
    "data_analysis": {
      "mode": "replay",
      "verbose": true,
      "output": "analysis_results",
      "description": "Data analysis and replay mode"
    },
    "system_test": {
      "mode": "gui",
      "profile": true,
      "verbose": true,
      "description": "Full system test with profiling"
    },
    "minimal": {
      "mode": "safe",
      "quiet": true,
      "no_auth": true,
      "description": "Minimal safe mode for recovery"
    },
    "mission_control": {
      "mode": "mission",
      "verbose": true,
      "theme": "modern_dark",
      "description": "CanSat mission control mode"
    }
  },
  
  "keyboard_shortcuts": {
    "quit": "Ctrl+Q",
    "fullscreen": "F11",
    "refresh": "F5",
    "settings": "Ctrl+,",
    "help": "F1",
    "console": "Ctrl+`",
    "screenshot": "Ctrl+PrtScn",
    "export_data": "Ctrl+E"
  },
  
  "notification_settings": {
    "enabled": true,
    "sound_enabled": true,
    "desktop_notifications": true,
    "email_notifications": false,
    "email_address": "",
    "notify_on_error": true,
    "notify_on_warning": true,
    "notify_on_milestone": true,
    "quiet_hours_enabled": false,
    "quiet_hours_start": "22:00",
    "quiet_hours_end": "08:00"
  },
  
  "plugins": {
    "enabled": true,
    "auto_load": true,
    "plugin_directory": "plugins",
    "whitelist": [],
    "blacklist": []
  },
  
  "experimental_features": {
    "quantum_enabled": true,
    "cosmic_enabled": true,
    "pipeline_enabled": true,
    "blockchain_enabled": false,
    "ar_vr_enabled": false,
    "voice_control": false
  }
}
